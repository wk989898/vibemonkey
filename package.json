{
  "name": "vibemonkey",
  "version": "2.35.0",
  "description": "VibeMonkey",
  "homepage": "https://github.com/wk989898/vibemonkey",
  "bugs": {
    "url": "https://github.com/wk989898/vibemonkey/issues"
  },
  "license": "MIT",
  "author": "wk989898 <nhsmwk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wk989898/vibemonkey.git"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "node scripts/build.mjs dev",
    "dev:chrome-mv3": "cross-env TARGET=chrome-mv3 node scripts/build.mjs dev",
    "prebuild": "npm run ci",
    "build": "cross-env NODE_ENV=production node scripts/build.mjs build",
    "build:chrome-mv3": "cross-env TARGET=chrome-mv3 NODE_ENV=production node scripts/build.mjs build",
    "build:selfHosted": "cross-env TARGET=selfHosted BETA=1 NODE_ENV=production node scripts/build.mjs build",
    "build:all": "run-s build build:chrome-mv3 build:selfHosted",
    "analyze": "cross-env RUN_ENV=analyze npm run build",
    "manifest": "node scripts/build.mjs manifest",
    "i18n": "node scripts/build.mjs i18n",
    "copyI18n": "node scripts/build.mjs copyI18n",
    "lint": "run-s lint:js lint:yml",
    "lint:js": "node scripts/lint-js.mjs",
    "lint:yml": "node scripts/build.mjs check",
    "format": "oxfmt --write --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx,vue}\" \"test/**/*.{ts,tsx,vue}\" \"scripts/**/*.mjs\" \"*.{json,mjs,ts}\" \".postcssrc.mjs\"",
    "format:check": "oxfmt --check --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx,vue}\" \"test/**/*.{ts,tsx,vue}\" \"scripts/**/*.mjs\" \"*.{json,mjs,ts}\" \".postcssrc.mjs\"",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "cross-env TEST=test node scripts/test.mjs",
    "ci": "run-p lint test typecheck",
    "bumpVersion": "node scripts/build.mjs bump",
    "bump": "run-s ci \"bumpVersion --commit\"",
    "preversion": "run-s ci \"bumpVersion --reset\""
  },
  "dependencies": {
    "@violentmonkey/shortcut": "^1.4.4",
    "@zip.js/zip.js": "2.4.4",
    "codemirror": "^5.65.20",
    "tldts": "^7.0.19",
    "vue": "^3.5.25",
    "vueleton": "^2.0.2"
  },
  "devDependencies": {
    "@actions/core": "^1.9.0",
    "@actions/github": "^5.0.3",
    "@iconify-json/mdi": "^1.2.3",
    "@types/chrome": "^0.0.208",
    "@types/firefox-webext-browser": "94.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.5.25",
    "amo-upload": "^0.5.5",
    "autoprefixer": "^10.4.15",
    "chokidar": "^4.0.3",
    "cross-env": "^7.0.3",
    "cross-spawn": "^7.0.3",
    "husky": "^8.0.1",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "oxc-parser": "^0.121.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "plugin-error": "^2.0.0",
    "postcss": "^8.4.28",
    "postcss-calc": "^9.0.1",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "postcss-scss": "^4.0.4",
    "postcss-simple-vars": "^6.0.3",
    "sharp": "^0.32.6",
    "through2": "^4.0.2",
    "typescript": "^5.1.6",
    "unplugin-icons": "^23.0.1",
    "vinyl": "^2.2.1",
    "vite": "^8.0.3",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.29"
  },
  "engines": {
    "node": ">=20 <22 || >= 24"
  },
  "beta": 1
}
